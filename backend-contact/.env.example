# Variáveis de ambiente do backend de contato.
# Copie para .env e preencha com seus valores reais. NÃO comite o .env real.

PORT=3001
HOST=127.0.0.1

# SMTP UOL Host
SMTP_HOST=smtp.uhserver.com
SMTP_PORT=587
SMTP_USER=comercial@diretacargas.com.br
SMTP_PASSWORD=troque-aqui

# Para onde os e-mails do formulário serão enviados
CONTACT_TO=comercial@diretacargas.com.br

# Origem permitida (CORS). Use o domínio do site em produção.
ALLOWED_ORIGIN=https://diretacargas.com.br
